//NAU7802 defs
int32_t zeroOffset = -3656;
float cbFactor = 6982.8716;

#define baud 115200
float Vbatt;
#define battPin 0

float currentForce;
float lastForce;
uint32_t lastMillis;
uint16_t xPos = 10;
uint16_t yPos = 0;

uint8_t currentSPM;
uint8_t SPMbuffer = 3;
uint8_t SPMi = 0;

float strokeForceSum = 0;
uint32_t strokeSampleCount = 0;
float peakForce = 0;
float avgForce = 0;
bool prevLastLoopStroke = false;
float peakAcc = 0;
float minAcc = 0;
float currentAcc = 0;
bool firstAccSample = true;
bool lastLoopStroke = false;
bool firstStroke = true;
uint32_t cT;
uint32_t lastInputTime;
uint8_t dbDelay = 800;
float rawSPM;
bool dataMode = false;
// BLE setup
BLECharacteristic *pCharacteristic;
#define BLE_SERVICE_UUID "12345678-1234-5678-1234-56789abcdef0"
#define BLE_CHARACTERISTIC_UUID "abcdef01-1234-5678-1234-56789abcdef0"

//initialize input device objects
Adafruit_ILI9341 tft = Adafruit_ILI9341(TFT_cs, TFT_dc, TFT_mosi, TFT_sck, TFT_rst, TFT_miso);  // display
