  tft.setTextSize(3);
  tft.println("openRow");
  tft.setCursor(10, 180);
  tft.setTextSize(1);
  tft.println("Author: Zach Malkani - ACES '27");
  tft.setCursor(10, 190);
  tft.print("V5 Firmware - Prototype Hardware");
  delay(1500);
  tft.fillScreen(ILI9341_WHITE);

  if (!dataMode) {
    Serial.println("Force Curve Mode ");
    
    tft.drawRect(11, 0, 311, 224, 0x0);

    tft.drawRect(12, 0, 311, 222, 0x0);

    tft.drawRect(10, -1, 311, 224, 0x0);

    tft.setTextColor(0x0);
    tft.setTextWrap(false);
    tft.setCursor(2, 102);
    tft.print("N");

    tft.setCursor(124, 229);
    tft.print("Time (s)");
  }

  if (dataMode) {

    tft.setTextColor(0x0);
    tft.setTextSize(8);
    tft.setTextWrap(false);
    tft.setCursor(22, 22);

    tft.setTextSize(2);
    tft.setFont(&Petme8x8);
    tft.setCursor(1, 99);
    tft.print("spm");

    tft.drawLine(0, 0, 0, 0, 0xFFFF);

    tft.drawLine(140, 238, 148, 10, 0xFFFF);

    tft.fillRect(141, 0, 6, 240, 0x0);

    tft.fillRect(-4, 101, 147, 7, 0x0);

    tft.fillRect(145, 145, 177, 7, 0x0);

    tft.fillRect(144, 71, 177, 7, 0x0);

    tft.fillRect(143, 210, 177, 7, 0x0);

    tft.drawLine(0, 0, 0, 0, 0xF206);

    tft.setTextSize(1);
    tft.setCursor(151, 68);
    tft.print("max m/s^2");

    tft.setTextSize(5);
    tft.setFont();
    tft.setCursor(218, 10);
   

    tft.setTextSize(1);
    tft.setFont(&Petme8x8);
    tft.setCursor(151, 142);
    tft.print("min m/s^2");

    tft.setTextSize(5);
    tft.setFont();
    tft.setCursor(222, 94);

    tft.setTextSize(1);
    tft.setFont(&Petme8x8);
    tft.setCursor(11, 220);
    tft.print("avg. force");

    tft.setTextSize(8);
    tft.setFont();
    tft.setCursor(2, 137);

    tft.setTextSize(6);
    tft.setCursor(171, 157);

    tft.setTextSize(1);
    tft.setFont(&Petme8x8);
    tft.setCursor(148, 209);
    tft.print("peak force");
  }

  //BLE broadcast service setup
  delay(1000);  //power buffer
  BLEDevice::init("openRow unit 1");
  
  BLEServer *pServer = BLEDevice::createServer();

  BLEService *pService = pServer->createService(BLE_SERVICE_UUID);
  pCharacteristic = pService->createCharacteristic(
    BLE_CHARACTERISTIC_UUID,
    NIMBLE_PROPERTY::READ | NIMBLE_PROPERTY::WRITE | NIMBLE_PROPERTY::NOTIFY);
  pService->start();

  BLEAdvertising *pAdvertising = BLEDevice::getAdvertising();
  pAdvertising->addServiceUUID(BLE_SERVICE_UUID);
  pAdvertising->start();

  Serial.println("BLE advertising as 'openRow'");
}

void loop() {
  cT = millis();
  //print out force reading in serial when nau is available to avoid hanging
  if (nau.available()) {
    // convert raw reading to newtons w/ formula :   ((raw - rawoffset) / calibration factor) * conversion to N
    currentForce = ((nau.read() - zeroOffset) / cbFactor) * 9.81;
  }

  sensors_event_t a, g, temp;
  mpu.getEvent(&a, &g, &temp);
  currentAcc = sqrt(sq(a.acceleration.x) + sq(a.acceleration.y) + sq(a.acceleration.z));

  //convert force reading into pixel scale
  yPos = 221 - (currentForce * (216.0 / 1000.0));  // CHANGE DENOMINATOR TO CHANGE Y-AXIS SCALE

  xPos += 2;  //x increment
  //wrap around x axis
  if (xPos > 320) {
    xPos = 10;
  }

  //if no input reset to start
  if (currentForce < 18) {
    xPos = 13;
  }

  yPos = constrain(yPos, 5, 221);
  if (!dataMode) {
    tft.drawFastVLine((xPos + 2), 7, 215, ILI9341_WHITE);
    tft.drawFastVLine((xPos + 1), 7, 215, ILI9341_WHITE);
    //draws 3 adjacent pixels red, the middle one being the real data point and the other 3 on each side to make the line thicker
    tft.drawPixel(xPos, yPos + 1, ILI9341_RED);
    tft.drawPixel(xPos, yPos + 2, ILI9341_RED);
    tft.drawPixel(xPos, yPos, ILI9341_RED);
    tft.drawPixel(xPos, yPos + 2, ILI9341_RED);
    tft.drawPixel(xPos, yPos - 1, ILI9341_RED);

    tft.drawPixel(xPos + 1, yPos + 1, ILI9341_RED);
    tft.drawPixel(xPos + 1, yPos + 2, ILI9341_RED);
    tft.drawPixel(xPos + 1, yPos, ILI9341_RED);
    tft.drawPixel(xPos + 1, yPos + 2, ILI9341_RED);
    tft.drawPixel(xPos + 1, yPos - 1, ILI9341_RED);
  }

  //refresh screen if quiet for a while logic
  if (!dataMode) {
    static uint32_t timeZeroForce = 0;
    if (currentForce < 10) {
      if (timeZeroForce == 0) { timeZeroForce = millis(); }
      if (millis() - timeZeroForce > 6000) {
        tft.fillRect(14, 1, 307, 221, ILI9341_WHITE);
        //reference variables: (int16_t x, int16_t y, int16_t w, int16_t h, uint16_t color)
        timeZeroForce = 0;
      }
    } else {
      timeZeroForce = 0;
    }
  }

  bool overThreshold = (currentForce > 100 && lastForce <= 100);

  //calculate SPM using modified MBC RPM calculation logic
  if (overThreshold && !lastLoopStroke) {
    if (cT - lastInputTime > dbDelay) {
      if (lastInputTime != 0 || firstStroke) {
        firstStroke = false;
        uint32_t dT = cT - lastInputTime;
        rawSPM = 60000.0 / (float)dT;
        lastInputTime = cT;
        lastLoopStroke = true;
      }
    }
  } else {
    if (currentForce < 30) {
      lastLoopStroke = false;
    }
  }

  // Update Display via Core 0
  currentSPM = (uint8_t)rawSPM;
  if (dataMode) {
    // accumulate Force values and max/min acceleration during stroke, 
    // divide the sum by the number of samples when stroke ends, call that avgForce whilst we're at it
    if (lastLoopStroke) {
      strokeForceSum += currentForce;
      strokeSampleCount++;
      if (currentForce > peakForce) peakForce = currentForce;
    }

    if (lastLoopStroke) {
      if (firstAccSample) {
        minAcc = currentAcc;
        firstAccSample = false;
      }
      if (currentAcc > peakAcc) peakAcc = currentAcc;
      if (currentAcc < minAcc) minAcc = currentAcc;
    }

    // on stroke end, calculate and display
    if (prevLastLoopStroke && !lastLoopStroke) {
      if (strokeSampleCount > 0) avgForce = strokeForceSum / strokeSampleCount;

      tft.setFont();
      tft.setTextColor(ILI9341_BLACK, ILI9341_WHITE);
      tft.setTextSize(8);
      tft.setCursor(22, 20);
      tft.print(currentSPM);

      tft.setTextSize(7);
      tft.setCursor(9, 142);
      tft.print((int)avgForce);

      tft.setTextSize(5);
      tft.setCursor(181, 160);
      tft.print((int)peakForce);

      tft.setFont();
      tft.setTextSize(5);
      tft.setTextColor(ILI9341_BLACK, ILI9341_WHITE);
      tft.setCursor(194, 10);
      tft.print(peakAcc, 1);

      tft.setCursor(194, 94);
      tft.print(minAcc, 1);

      // reset accumulators
      strokeForceSum = 0;
      strokeSampleCount = 0;
      peakForce = 0;
      peakAcc = 0;
      minAcc = 0;
      firstAccSample = true;
    }

    prevLastLoopStroke = lastLoopStroke;
  }

  //BLE broadcast
  char bleBuffer[64];
  snprintf(bleBuffer, sizeof(bleBuffer), "%lu,%.1f,%.2f,%.2f",
           (unsigned long)cT, (float)currentSPM, currentAcc, currentForce);
  pCharacteristic->setValue(bleBuffer);
  pCharacteristic->notify();

  if (SPMi > SPMbuffer) {
    SPMi = 0;
  }
  SPMi++;
}
