void loop() {
  cT = millis();
  //print out force reading in serial when nau is available to avoid hanging
  if (nau.available()) {
    // convert raw reading to newtons w/ formula :   ((raw - rawoffset) / calibration factor) * conversion to N
    currentForce = ((nau.read() - zeroOffset) / cbFactor) * 9.81;
  }
  Serial.println(currentForce);


  //convert force reading into pixel scale
  yPos = 120 - (currentForce * (115.0 / 1000.0));  // CHANGE DENOMENATOR TO CHANGE Y-AXIS SCALE

  xPos++;  //x increment
  //wrap around x axis
  if (xPos > 355) {
    xPos = 10;
  }

  //if no input reset to start
  if (currentForce < 15) {
    xPos = 10;
  }

  yPos = constrain(yPos, 5, 118);

  if (xSemaphoreTake(tftMutex, pdMS_TO_TICKS(10))) {
    tft.drawFastVLine((xPos + 1), 7, 111, ILI9341_WHITE);
    tft.drawPixel(xPos, yPos, ILI9341_RED);
    xSemaphoreGive(tftMutex);
  }

  //refresh screen if quiet for a while
  static uint32_t timeZeroForce = 0;
  if (currentForce < 10) {
    if (timeZeroForce == 0) { timeZeroForce = millis(); }
    if (millis() - timeZeroForce > 5000) {
      if (xSemaphoreTake(tftMutex, portMAX_DELAY)) {
        tft.fillRect(12, 7, 296, 111, ILI9341_WHITE);
        xSemaphoreGive(tftMutex);
      }
      timeZeroForce = 0;
    }
  } else {
    timeZeroForce = 0;
  }




  // Determine if threshold is met w/ REAL si unit name "yank" - meaning the 1st derivative of force (N/s)

  float yank = 0;
  uint32_t dt = cT - lastMillis;
  if (dt >= 5) {
    yank = (currentForce - lastForce) / (float)dt;
  }
  //bool overThreshold = (yank > yankThreshold);
  //Serial.println(yank);

  bool overThreshold = (currentForce > 100 && lastForce <= 100);

  if (overThreshold && !lastLoopStroke) {
    //Serial.println("OVER THRESHOLD");
    if (cT - lastInputTime > dbDelay) {
      //Serial.println("PAST DEBOUNCE");
      if (lastInputTime != 0 || firstStroke) {
        Serial.println("STROKE DETECTED");
        firstStroke = false;
        uint32_t dT = cT - lastInputTime;
        rawSPM = 60000.0 / (float)dT;
        lastInputTime = cT;
        lastLoopStroke = true;
      }
    }
  } else {
    if (currentForce < 30) {
      lastLoopStroke = false;
    }
  }

  // Update Display via Core 0
  currentSPM = (uint8_t)rawSPM;
  if (currentSPM != lastSPM) {
    writeSPM(currentSPM);
    lastSPM = currentSPM;
  }

  if (SPMi > SPMbuffer) {
    SPMi = 0;
  }
  SPMi++;
}
