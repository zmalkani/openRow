//tft defs
#define TFT_cs 12
#define TFT_dc 27
#define TFT_rst 14
#define TFT_mosi 26
#define TFT_sck 25
#define TFT_miso 32

//hx711 defs
#define HX_data 23
#define HX_sck 22
const uint32_t HX_cb = 837031.06;  //calibration factor
#define HX_tare 33                  //tare button pin

#define baud 115200
float Vbatt;
#define battPin 0

float currentForce;
uint8_t xCpos;
uint8_t yCpos;

volatile bool newSPM = false;
volatile uint8_t currentSPM;
uint8_t lastSPM;
uint8_t SPMbuffer = 3;
uint8_t SPMi =0;
float mpuXthreshold = 30;
float mpuYthreshold = 30;
float mpuZthreshold = 30;
float resThreshold = 4;

float accX;
float accY;
float accZ;

float accXlast;
float accYlast;
float accZlast;

bool lastLoopStroke = false;
bool firstStroke = true;
uint32_t cT;
uint32_t lastInputTime;
uint8_t dbDelay = 400;
float rawSPM;

// Impulse logic variables
uint32_t impulseStartTime = 0; 
bool checkingImpulse = false;
uint32_t impulseThreshold = 30; // ms acceleration must stay above threshold

//initialize input objects
Adafruit_ILI9341 tft = Adafruit_ILI9341(TFT_cs, TFT_dc, TFT_mosi, TFT_sck, TFT_rst, TFT_miso);
HX711 s1;
Adafruit_MPU6050 mpu;

void displayTask(void *pvParameters){
  for(;;){
    if (newSPM){
      writeSPM(currentSPM);
      newSPM = false;
    }
    vTaskDelay(pdMS_TO_TICKS(50));
  }
}

void writeSPM(uint8_t spm){
  tft.setCursor(10,155);
  tft.setTextSize(8);
  tft.setTextColor(ILI9341_BLACK, ILI9341_WHITE); 
  spm = constrain(spm, 0, 99); 
  tft.print(spm);
}

