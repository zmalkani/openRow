void loop() {
  //print out force reading in serial
  s1.read(); 
  currentForce = s1.get_units(1) * 9.81;
  Serial.println("currentForce: "+(String)currentForce+"N");




  sensors_event_t a, g, temp;
  mpu.getEvent(&a, &g, &temp);
  accX = abs(a.acceleration.x);
  accY = abs(a.acceleration.y);
  accZ = abs(a.acceleration.z);
  cT = millis();

  // Determine if threshold is met
  bool overThreshold = (accX > mpuXthreshold || accZ > mpuZthreshold || accY > mpuYthreshold);

  if (overThreshold && !lastLoopStroke) {
    if (!checkingImpulse) {
      // Catch the initial timestamp
      impulseStartTime = cT;
      checkingImpulse = true;
    } 
    else if (cT - impulseStartTime >= impulseThreshold) {
      // Verified sustained pull
      if (cT - lastInputTime > dbDelay) {
        if (lastInputTime != 0 || firstStroke) {
          firstStroke = false;
          Serial.println("STROKE" + (String)cT);
          uint32_t dT = cT - lastInputTime;
          rawSPM = 60000.0 / (float)dT;
          lastInputTime = cT;
          lastLoopStroke = true; 
          checkingImpulse = false;
        }
      }
    }
  } else {
    // Drop logic: reset timer and allow new stroke once physical force is gone
    checkingImpulse = false;
    if (!overThreshold) {
      lastLoopStroke = false;
    }
  }

  // Update Display via Core 0
  currentSPM = (uint8_t)rawSPM;
  if ((currentSPM != lastSPM) && SPMi < SPMbuffer) {
    newSPM = true;
    lastSPM = currentSPM;
  }

  if (SPMi > SPMbuffer) {
    SPMi = 0;
  }
  SPMi++;
}
